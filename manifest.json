{
  "manifest_version": 3,
  "name": "Slack Bulk Delete",
  "version": "0.1.1",
  "description": "Bulk deletion for your own Slack messages using direct Slack Web API calls.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "webRequest",
    "sidePanel"
  ],
  "host_permissions": [
    "https://slack.com/*",
    "https://*.slack.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "app.html"
  },
  "action": {
    "default_title": "Slack Bulk Delete",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
